@model FitCore.Models.Subscription

<h2>Assign Membership Plan</h2>
<hr />

<div class="row">
    <div class="col-md-4">
        <form asp-action="Create" method="post">
            
            <div class="form-group mb-3">
                <label class="control-label">Select Member</label>
                <select asp-for="MemberId" class="form-control" asp-items="ViewBag.Members"></select>
            </div>
            
            <div class="form-group mb-3">
                <label asp-for="PlanName" class="control-label">Plan Name</label>
                <select asp-for="PlanName" class="form-control">
                    <option value="1 Month">1 Month</option>
                    <option value="3 Months">3 Months</option>
                    <option value="6 Months">6 Months</option>
                    <option value="1 Year VIP">1 Year VIP</option>
                </select>
            </div>

            <div class="form-group mb-3">
                <label asp-for="EndDate" class="control-label">End Date</label>
                <input asp-for="EndDate" type="date" class="form-control" />
            </div>

            <div class="form-group mb-3">
                <label asp-for="Price" class="control-label">Price (₺)</label>
                <input asp-for="Price" type="number" class="form-control" />
            </div>
            
            <div class="form-group">
                <input type="submit" value="Save Plan" class="btn btn-success" />
                <a asp-action="Index" class="btn btn-secondary">Back to List</a>
            </div>
        </form>
    </div>
</div>