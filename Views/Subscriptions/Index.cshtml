@model IEnumerable<FitCore.Models.Subscription>

<h2>Subscriptions</h2>
<a asp-action="Create" class="btn btn-primary mb-3">Assign New Plan</a>

<table class="table table-bordered table-striped">
    <thead class="table-dark">
        <tr>
            <th>Member Name</th>
            <th>Plan Name</th>
            <th>Start Date</th>
            <th>End Date</th>
            <th>Price (₺)</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Member.FullName</td> 
                <td>@item.PlanName</td>
                <td>@item.StartDate.ToString("dd/MM/yyyy")</td>
                <td>@item.EndDate.ToString("dd/MM/yyyy")</td>
                <td>@item.Price</td>
            </tr>
        }
    </tbody>
</table>